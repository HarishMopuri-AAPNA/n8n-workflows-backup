        "respondWith": "text",
        "responseBody": "=<!DOCTYPE html>\n<html>\n<head>\n  <title>Complete Your Profile</title>\n  <style>\n    *{box-sizing:border-box}\n    body{font-family:Inter,system-ui,-apple-system,BlinkMacSystemFont,sans-serif;background:#f9fafb;margin:0;padding:40px;color:#111827}\n    .card{max-width:520px;background:#fff;margin:auto;padding:32px;border-radius:12px;box-shadow:0 10px 25px rgba(0,0,0,.06)}\n    h2{margin:0 0 8px;font-size:24px;font-weight:700}\n    h3{margin:0 0 24px;font-size:18px;font-weight:600;color:#6b7280}\n    label{display:block;margin-top:20px;margin-bottom:6px;font-weight:600;font-size:14px}\n    input[type=text],textarea,select{width:100%;padding:12px 14px;border-radius:8px;border:1px solid #d1d5db;font-size:14px;outline:none;background:#f9fafb;font-family:inherit}\n    input[type=text]:focus,textarea:focus,select:focus{border-color:#6366f1;background:#fff;box-shadow:0 0 0 2px rgba(99,102,241,.15)}\n    .upload-box{border:2px dashed #d1d5db;border-radius:8px;padding:28px;text-align:center;margin-top:6px;cursor:pointer;transition:.2s}\n    .upload-box:hover{border-color:#6366f1;background:#f0f0ff}\n    .upload-fname{font-size:13px;color:#6366f1;margin-top:8px;font-weight:600;word-break:break-all}\n    .upload-hint{font-size:13px;color:#6b7280;margin-top:8px}\n    #submitBtn{margin-top:28px;width:100%;padding:12px;background:#6366f1;color:#fff;border:none;border-radius:8px;font-size:15px;font-weight:600;cursor:pointer;transition:background .2s}\n    #submitBtn:hover{background:#4f46e5}\n    #submitBtn:disabled{background:#9ca3af;cursor:not-allowed}\n    .required{color:#ef4444;font-weight:bold;margin-left:4px}\n    .field-group{margin-bottom:4px}\n    .msg{display:none;margin-top:14px;padding:10px 14px;border-radius:8px;font-size:13px;text-align:center}\n    .msg.err{background:#fee2e2;color:#991b1b}\n    .msg.ok{background:#dcfce7;color:#166534}\n  </style>\n</head>\n<body>\n<div class=\"card\">\n  <h2>Hi {{ $('Select rows - Basis of Token').item.json.Name.split(' ').map(w => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase()).join(' ') }}</h2>\n  <h3>Complete Your Profile</h3>\n  <script type=\"application/json\" id=\"n8nToken\">{{ $json.token }}</script>\n  <script type=\"application/json\" id=\"n8nFields\">{{ JSON.stringify($json.fields) }}</script>\n  <div id=\"dynamicFields\"></div>\n  <button type=\"button\" id=\"submitBtn\" onclick=\"submitForm()\">Submit</button>\n  <div class=\"msg\" id=\"statusMsg\"></div>\n</div>\n<script>\n  var TOKEN  = document.getElementById('n8nToken').textContent.trim();\n  var FIELDS = JSON.parse(document.getElementById('n8nFields').textContent);\n  var container = document.getElementById('dynamicFields');\n\n  FIELDS.forEach(function(f) {\n    var wrap = document.createElement('div');\n    wrap.className = 'field-group';\n    var lbl = document.createElement('label');\n    lbl.innerHTML = f.label + ' <span class=\"required\">*</span>';\n    wrap.appendChild(lbl);\n\n    if (f.type === 'dropdown') {\n      var sel = document.createElement('select');\n      sel.id = 'field_' + f.name; sel.name = f.name; sel.required = true;\n      var blank = document.createElement('option');\n      blank.value = ''; blank.textContent = 'Select';\n      sel.appendChild(blank);\n      (f.options || []).forEach(function(opt) {\n        var o = document.createElement('option');\n        o.value = opt; o.textContent = opt;\n        if (f.value === opt) o.selected = true;\n        sel.appendChild(o);\n      });\n      wrap.appendChild(sel);\n\n    } else if (f.type === 'textarea') {\n      var ta = document.createElement('textarea');\n      ta.id = 'field_' + f.name; ta.name = f.name;\n      ta.required = true; ta.rows = 4; ta.value = f.value || '';\n      wrap.appendChild(ta);\n\n    } else if (f.type === 'file') {\n      var box = document.createElement('div');\n      box.className = 'upload-box';\n      box.innerHTML =\n        '<svg width=\"36\" height=\"36\" fill=\"none\" stroke=\"#9ca3af\" stroke-width=\"2\" viewBox=\"0 0 24 24\">' +\n          '<path d=\"M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4\"/>' +\n          '<polyline points=\"17 8 12 3 7 8\"/>' +\n          '<line x1=\"12\" y1=\"3\" x2=\"12\" y2=\"15\"/>' +\n        '</svg>' +\n        '<p class=\"upload-hint\">Click to browse file (.pdf, .doc, .docx)</p>' +\n        '<div class=\"upload-fname\" id=\"fname_' + f.name + '\">No file chosen</div>';\n      var fi = document.createElement('input');\n      fi.type = 'file'; fi.id = 'field_' + f.name; fi.name = f.name;\n      fi.accept = '.pdf,.doc,.docx'; fi.required = true; fi.style.display = 'none';\n      fi.addEventListener('change', (function(name) {\n        return function() {\n          var el = document.getElementById('fname_' + name);\n          var inp = document.getElementById('field_' + name);\n          el.textContent = (inp.files && inp.files[0]) ? inp.files[0].name : 'No file chosen';\n        };\n      })(f.name));\n      box.appendChild(fi);\n      box.addEventListener('click', (function(name) {\n        return function(e) {\n          var inp = document.getElementById('field_' + name);\n          if (e.target !== inp) inp.click();\n        };\n      })(f.name));\n      wrap.appendChild(box);\n\n    } else {\n      var inp = document.createElement('input');\n      inp.type = 'text'; inp.id = 'field_' + f.name; inp.name = f.name;\n      inp.required = true; inp.value = f.value || '';\n      wrap.appendChild(inp);\n    }\n    container.appendChild(wrap);\n  });\n\n  function submitForm() {\n    var btn = document.getElementById('submitBtn');\n    var msg = document.getElementById('statusMsg');\n    var valid = true;\n    FIELDS.forEach(function(f) {\n      var el = document.getElementById('field_' + f.name);\n      if (!el) return;\n      if (f.type === 'file') { if (!el.files || el.files.length === 0) valid = false; }\n      else { if (!el.value || el.value.trim() === '') valid = false; }\n    });\n    if (!valid) {\n      msg.textContent = 'Please fill in all required fields.';\n      msg.className = 'msg err'; msg.style.display = 'block'; return;\n    }\n    btn.disabled = true; btn.textContent = 'Submitting...'; msg.style.display = 'none';\n\n    // ── Fetch A: text fields → Step 1.1.3 (existing, untouched) ──────────────\n    var textFd = new FormData();\n    textFd.append('token', TOKEN);\n    FIELDS.forEach(function(f) {\n      if (f.type !== 'file') {\n        var el = document.getElementById('field_' + f.name);\n        if (el) textFd.append(f.name, el.value || '');\n      }\n    });\n\n    // ── Fetch B: file only → Step 1.1.3b (new upload workflow) ──────────────\n    var fileField = FIELDS.find(function(f) { return f.type === 'file'; });\n    var fileFd = null;\n    if (fileField) {\n      var fileEl = document.getElementById('field_' + fileField.name);\n      if (fileEl && fileEl.files && fileEl.files[0]) {\n        fileFd = new FormData();\n        fileFd.append('token', TOKEN);\n        fileFd.append('uploadResume', fileEl.files[0]);\n      }\n    }\n\n    var promises = [\n      fetch('/webhook/3295be42-0999-404c-842c-a43f0135d611', { method: 'POST', body: textFd })\n        .then(function(r) { return r.text(); })\n    ];\n    if (fileFd) {\n      promises.push(\n        fetch('/webhook/cv-upload-missing-jd/staging', { method: 'POST', body: fileFd })\n          .then(function(r) { return r.text(); })\n      );\n    }\n\n    Promise.all(promises)\n      .then(function() {\n        // Hide all dynamic fields\n        document.getElementById('dynamicFields').style.display = 'none';\n        // Hide the submit button\n        btn.style.display = 'none';\n        // Hide the h3 subtitle\n        var h3 = document.querySelector('.card h3');\n        if (h3) h3.style.display = 'none';\n        // Show success message\n        msg.textContent = 'Profile updated successfully! Thank you.';\n        msg.className = 'msg ok'; msg.style.display = 'block';\n      })\n      .catch(function() {\n        msg.textContent = 'Submission failed. Please try again.';\n        msg.className = 'msg err'; msg.style.display = 'block';\n        btn.disabled = false; btn.textContent = 'Submit';\n      });\n  }\n</script>\n</body>\n</html>",
