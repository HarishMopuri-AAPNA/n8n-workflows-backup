        "jsCode": "const rawMissingData = $json.missingData;\n\nconst missingData =\n  typeof rawMissingData === \"string\"\n    ? JSON.parse(rawMissingData)\n    : rawMissingData;\n\n// ============================================================\n// OLD Label mapping (commented out for reference)\n// ============================================================\n// const labelMap = {\n//   CurrentLocation: \"What is your current location?\",\n//   EnglishCommunicationRating:\n//     \"How much do you rate your English communication skills out of 5 (5 being the highest)?\",\n//   Top5KeySkills:\n//     \"Mention top 5 key skills you have for this job role?\",\n//   ExpectedCTC_LPA:\n//     \"Expected CTC (In LPA)\",\n// };\n// ============================================================\n\n// Label mapping  (KEY = Field Name, VALUE = Form Question)\n// Source: matched_fields_mapping.xlsx\n// Note: Yellow rows (EducationalScoresPercentage.*) are excluded\nconst labelMap = {\n  Name:                       \"Name\",\n  NoticePeriod:               \"What is your official notice period?\",\n  ContactNumber:              \"What is your Contact Number?\",\n  EmailID:                    \"Email ID\",\n  HighestQualification:       \"What is your highest Qualification?\",\n  TotalExperienceYears:       \"What is your total experience (in Years)?\",\n  LastCompanyExperienceYears: \"What is your experience with your last company (in Years)?\",\n  CurrentLocation:            \"What is your current location?\",\n  CTC_LPA:                    \"What is your CTC (In LPA)?\",\n  ExpectedCTC_LPA:            \"What is your Expected CTC (In LPA)?\",\n  JobSource:                  \"From which source you got to know about this job opportunity?\",\n  RecruiterInfoAAPNA:         \"Share the recruiter's information who contacted you from AAPNA\",\n  PositionApplied:            \"Please mention the position name you are applying for\",\n  Top5KeySkills:              \"Mention top 5 key skills you have for this job role\",\n  CurrentCompany:             \"What is your current company name and website address?\",\n  Gender:                     \"Gender\",\n  EnglishCommunicationRating: \"How much you rate your English communication skills out of 5 (5 being the highest)?\",\n  PreferredShift:             \"Which shift timing is suitable for you?\",\n  ReasonForJobChange:         \"What is your reason for job change?\",\n  WillingToTakeOnlineTest:    \"Our online test is the mandatory part of AAPNA's interview process. Are you willing to take it?\",\n  HasLaptopForInitialDays:    \"Do you have a good working laptop (minimum 8 GB Ram) to start your job for initial 15 days?\",\n  LinkedInProfile:            \"LinkedIn profile link?\",\n  uploadResume:               \"Upload Resume\",\n};\n\n// ============================================================\n// Field type mapping\n// Source: test3.js — input types inferred from form field elements\n//   dropdown  → <select> in test3.js\n//   textarea  → <textarea> in test3.js\n//   text      → <input type=\"text\"> in test3.js (default)\n// ============================================================\nconst typeMap = {\n  // --- Dropdowns (from <select> elements in test3.js) ---\n  EnglishCommunicationRating: \"dropdown\",\n  Gender:                     \"dropdown\",\n  PreferredShift:             \"dropdown\",\n  WillingToTakeOnlineTest:    \"dropdown\",\n  HasLaptopForInitialDays:    \"dropdown\",\n\n  // --- Textareas (from <textarea> elements in test3.js) ---\n  Top5KeySkills:              \"textarea\",\n  ReasonForJobChange:         \"textarea\",\n  CurrentCompany:             \"textarea\",\n\n  // --- File upload ---\n  uploadResume:               \"file\",\n\n  // --- Explicit text fields ---\n  CurrentLocation:            \"text\",\n  ExpectedCTC_LPA:            \"text\",\n  CTC_LPA:                    \"text\",\n  NoticePeriod:               \"text\",\n  TotalExperienceYears:       \"text\",\n  LastCompanyExperienceYears: \"text\",\n  HighestQualification:       \"text\",\n  PositionApplied:            \"text\",\n  JobSource:                  \"text\",\n  RecruiterInfoAAPNA:         \"text\",\n  LinkedInProfile:            \"text\",\n  Name:                       \"text\",\n  EmailID:                    \"text\",\n  ContactNumber:              \"text\",\n};\n\n// ============================================================\n// Dropdown options mapping\n// Source: test3.js — options taken directly from each <select>\n// ============================================================\nconst optionsMap = {\n  EnglishCommunicationRating: [\"1\", \"2\", \"3\", \"4\", \"5\"],\n  Gender:                     [\"Male\", \"Female\", \"Other\"],\n  PreferredShift:             [\"2pm - 11pm/3pm - 12am\", \"4pm - 1am\", \"Others\"],\n  WillingToTakeOnlineTest:    [\"Yes\", \"No\"],\n  HasLaptopForInitialDays:    [\"Yes\", \"No\"],\n};\n\nconst formatLabel = (key) => {\n  return key\n    .replace(/_/g, \" \")\n    .replace(/([a-z])([A-Z])/g, \"$1 $2\")\n    .replace(/\\b\\w/g, (char) => char.toUpperCase());\n};\n\nconst fields = Object.keys(missingData).map((key) => {\n  return {\n    name: key,\n    label: labelMap[key] || formatLabel(key),\n    type: typeMap[key] || \"text\",\n    options: optionsMap[key] || [],\n    value:\n      missingData[key] === \"Null\" || missingData[key] == null\n        ? \"\"\n        : missingData[key],\n  };\n});\n\nreturn [\n  {\n    json: {\n      fields,\n      token: $('Code - Get Token').first().json.token\n    },\n  },\n];"
